# name: test/sql/mlx_cache_prune.test
# description: partition-level zone-map pruning on cached columns
# group: [sql]

require duckdb_mlx

statement ok
SELECT mlx_cache_clear();

statement ok
CREATE TABLE t_prune AS SELECT range::DOUBLE AS x FROM range(3000000);

statement ok
SET mlx_min_rows = 1000;

# populate the GPU cache
statement ok
SELECT sum(x + 0.0) FROM t_prune;

# selective filter on x should prune early segments via zone maps
statement ok
SET VARIABLE gpu_sum = (SELECT sum(x + 0.0) FROM t_prune WHERE x > 2500000.5);

statement ok
SET VARIABLE prune_stats = mlx_cache_stats();

statement ok
SET mlx_execution = false;

query I
SELECT abs(getvariable('gpu_sum') - (SELECT sum(x) FROM t_prune WHERE x > 2500000.5)) /
       abs((SELECT sum(x) FROM t_prune WHERE x > 2500000.5)) < 1e-3;
----
true

statement ok
SET mlx_execution = true;

# at least one segment pruned on 3M monotonic rows with a high threshold
query I
SELECT getvariable('prune_stats')[2] > 0;
----
true

query I
SELECT getvariable('prune_stats')[1] > getvariable('prune_stats')[2];
----
true
